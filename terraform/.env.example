# Example environment configuration for deployment

# AWS Configuration
export AWS_PROFILE=default
export AWS_REGION=us-east-1

# Terraform Variables
export TF_VAR_project_name="magic-movie-machine"
export TF_VAR_environment="dev"
export TF_VAR_aws_region="us-east-1"
export TF_VAR_personalize_domain="VIDEO_ON_DEMAND"
export TF_VAR_dataset_group_name="personalize-video-on-demand-ds-group"
export TF_VAR_s3_bucket_prefix="mmm"
export TF_VAR_kinesis_shard_count=1
export TF_VAR_lambda_timeout=60
export TF_VAR_lambda_memory=256

# Personalize Configuration (fill in after creating resources)
export PERSONALIZE_CAMPAIGN_ARN="arn:aws:personalize:us-east-1:ACCOUNT_ID:campaign/YOUR_CAMPAIGN"
export DATASET_GROUP_ARN="arn:aws:personalize:us-east-1:ACCOUNT_ID:dataset-group/YOUR_DATASET_GROUP"
export TRACKING_ID="YOUR_TRACKING_ID"

# API Configuration
export API_ENDPOINT="https://YOUR_API_ENDPOINT/dev"
